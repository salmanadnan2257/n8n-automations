    },
    {
      "parameters": {
        "jsCode": "const choices = $node[\"Generate Overlay Text\"].json.choices;\n\nconst raw = Array.isArray(choices) && choices.length > 0\n  ? choices[0].message.content || \"\"\n  : \"\";\n\nconst text = raw\n  .replace(/\\n/g, ' ')\n  .replace(/[\"']/g, '')\n  .trim();\n\nlet splitIndex = text.lastIndexOf(' ', 45);\nif (splitIndex === -1) splitIndex = 45;\n\nconst line1 = text.slice(0, splitIndex).trim();\nconst line2 = text.slice(splitIndex).trim();\n\nreturn [\n  {\n    json: {\n      line1,\n      line2\n    }\n  }\n];\n\n"
      },
